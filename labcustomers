#!/usr/bin/env bash
# Launcher for the Lab Customers CLI. Resolves its own location so it works from any
# directory, and bakes in --project / --sysimage. If lab.so hasn't been built yet it
# still runs (just slowly — AWS.jl recompiles), with a one-line heads-up.
#
#   ./labcustomers list              # from inside LabCloud.jl/
#   labcustomers create ...          # if LabCloud.jl/ is on PATH
set -euo pipefail
# Resolve through symlinks so `here` is this launcher's real directory (the LabCloud.jl
# project root) even when invoked via a symlink on PATH. readlink -f isn't portable, so
# walk the link chain by hand.
source="${BASH_SOURCE[0]}"
while [[ -L "$source" ]]; do
  dir="$(cd -P -- "$(dirname -- "$source")" && pwd)"
  source="$(readlink -- "$source")"
  [[ "$source" != /* ]] && source="$dir/$source"
done
here="$(cd -P -- "$(dirname -- "$source")" && pwd)"
sysimage=()
if [[ -f "$here/lab.so" ]]; then
  sysimage=(--sysimage "$here/lab.so")
else
  echo "labcustomers: $here/lab.so not found — running without sysimage (slow; build with 'julia --project=$here $here/build_sysimage.jl')" >&2
fi
exec julia --project="$here" "${sysimage[@]}" "$here/LabCustomersAPI.jl" "$@"
