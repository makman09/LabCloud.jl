LAB_OPERATOR_ROLE_ARN=arn:aws:iam::12345678901:role/LabOperatorRole
AWS_REGION=us-east-1
# Maps to the `lab-operator` IAM user's static access key (from `terraform output
# -raw lab_operator_access_key_id` / `-raw lab_operator_secret_access_key`), configured
# locally via `aws configure --profile caucellcloud-lab-operator`. Used for everything:
# routine automation with no MFA, and (via the same identity's own virtual MFA device)
# the delete command's MFA-gated bypass-delete step.
AWS_PROFILE=caucellcloud-lab-operator
PHI_KMS_KEY_ALIAS=alias/phi-research-key
LAB_CUSTOMERS_GROUP=LabCustomers
LAB_VENDORS_GROUP=LabVendors
DB_PATH=lab_customers.db

NAS_RESEARCH_PATH=/Volumes/CaucellVolumeI/Research
NAS_VENDORS_PATH=/Volumes/CaucellVolumeI/Vendors
SYNC_PROGRESS_DIR=~/.caucell/sync_progress
SYNC_WORKERS=10
