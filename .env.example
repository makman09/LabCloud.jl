LAB_OPERATOR_ROLE_ARN=arn:aws:iam::12345678901:role/LabOperatorRole
AWS_REGION=us-east-1
# Maps to the `lab-operator` IAM user's static access key (from `terraform output
# -raw lab_operator_access_key_id` / `-raw lab_operator_secret_access_key`), configured
# locally via `aws configure --profile caucellcloud-lab-operator`.
AWS_PROFILE=caucellcloud-lab-operator
PHI_KMS_KEY_ALIAS=alias/phi-research-key
LAB_CUSTOMERS_GROUP=LabCustomers
LAB_VENDORS_GROUP=LabVendors
DB_PATH=lab_customers.db

NAS_RESEARCH_PATH=/Volumes/CaucellVolumeI/Research
# Local AWS CLI profile for the delete command's MFA-gated bypass-delete step. Must resolve
# to one of terraform's `bypass_user_arns` (a human admin identity, NOT the `lab-operator`
# service user) with an MFA device registered — it assumes the same LabOperatorRole above,
# just via its MFA-gated trust statement. Configure with e.g.
# `aws configure --profile caucellcloud`.
AWS_BYPASS_PROFILE=caucellcloud
SYNC_PROGRESS_DIR=~/.caucell/sync_progress
SYNC_WORKERS=10
